{
  "pages": [
    "pages/index/index",
    "pages/create/create",
    "pages/stats/stats",
    "pages/about/about",
    "pages/logs/logs"
  ],
  "usingComponents": {
    "van-icon": "@vant/weapp/icon/index",
    "van-popup": "@vant/weapp/popup/index",
    "van-tag": "@vant/weapp/tag/index",
    "van-overlay": "@vant/weapp/overlay/index",
    "van-transition": "@vant/weapp/transition/index"
  },
  "window": {
    "navigationBarTextStyle": "white",
    "navigationStyle": "custom",
    "backgroundColor": "#070b10"
  },
  "darkmode": true,
  "tabBar": {
    "color": "#758895",
    "selectedColor": "#23d3a6",
    "backgroundColor": "#0e1620",
    "borderStyle": "white",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "记录",
        "iconPath": "assets/icon/record.png",
        "selectedIconPath": "assets/icon/record-active.png"
      },
      {
        "pagePath": "pages/create/create",
        "text": "新建",
        "iconPath": "assets/icon/create.png",
        "selectedIconPath": "assets/icon/create-active.png"
      },
      {
        "pagePath": "pages/stats/stats",
        "text": "统计",
        "iconPath": "assets/icon/stats.png",
        "selectedIconPath": "assets/icon/stats-active.png"
      },
      {
        "pagePath": "pages/about/about",
        "text": "关于",
        "iconPath": "assets/icon/about.png",
        "selectedIconPath": "assets/icon/about-active.png"
      }
    ]
  },
  "style": "v2",
  "rendererOptions": {
    "skyline": {
      "defaultDisplayBlock": true,
      "disableABTest": true,
      "sdkVersionBegin": "3.0.0",
      "sdkVersionEnd": "15.255.255"
    }
  },
  "componentFramework": "glass-easel",
  "sitemapLocation": "sitemap.json",
  "lazyCodeLoading": "requiredComponents"
}