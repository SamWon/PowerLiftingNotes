<van-popup
  wx:if="{{show}}"
  show="{{show}}"
  position="bottom"
  round
  custom-style="background: var(--surface); {{mode === 'grouped' ? 'height: 72vh;' : 'max-height: 72vh;'}}"
  bind:close="onClose"
>
  <view class="exercise-sheet-inner">
    <view class="sheet-handle"></view>
    <view class="sheet-title">选择训练动作</view>

    <!-- 分组模式：显示肌群 tab -->
    <block wx:if="{{mode === 'grouped'}}">
      <view class="exercise-tabs-grid">
        <view
          wx:for="{{exerciseGroups}}"
          wx:key="id"
          class="exercise-tab-card {{activeGroupId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onSwitchGroup"
        >
          <image class="exercise-tab-card-img" src="{{item.imageUrl}}" mode="aspectFit" />
          <text class="exercise-tab-card-label">{{item.label}}</text>
          <view wx:if="{{activeGroupId === item.id}}" class="exercise-tab-card-bar"></view>
        </view>
      </view>
      <scroll-view scroll-y="{{true}}" enhanced="{{true}}" class="exercise-scroll">
        <block wx:for="{{exerciseGroups}}" wx:key="id" wx:for-item="group">
          <view wx:if="{{activeGroupId === group.id}}" class="exercise-grid">
            <view
              wx:for="{{group.cards}}"
              wx:key="name"
              wx:for-item="item"
              class="exercise-option {{selectedName === item.name ? 'active' : ''}}"
              data-name="{{item.name}}"
              bindtap="onSelect"
            >
              <view class="exercise-thumb">
                <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" class="exercise-thumb-img" />
                <view wx:else class="exercise-thumb-fallback">
                  <text class="exercise-thumb-initial">{{item.initial}}</text>
                </view>
              </view>
              <view class="exercise-option-name">{{item.name}}</view>
              <view wx:if="{{item.shortDesc}}" class="exercise-option-desc">{{item.shortDesc}}</view>
            </view>
          </view>
        </block>
      </scroll-view>
    </block>

    <!-- 平铺模式：直接展示卡片列表 -->
    <block wx:else>
      <scroll-view scroll-y="{{true}}" enhanced="{{true}}" class="exercise-scroll">
        <view class="exercise-grid">
          <view
            wx:for="{{exerciseCards}}"
            wx:key="name"
            class="exercise-option {{selectedName === item.name ? 'active' : ''}}"
            data-name="{{item.name}}"
            bindtap="onSelect"
          >
            <view class="exercise-thumb">
              <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" class="exercise-thumb-img" />
              <view wx:else class="exercise-thumb-fallback">
                <text class="exercise-thumb-initial">{{item.initial}}</text>
              </view>
            </view>
            <view class="exercise-option-name">{{item.name}}</view>
            <view wx:if="{{item.shortDesc}}" class="exercise-option-desc">{{item.shortDesc}}</view>
          </view>
        </view>
      </scroll-view>
    </block>
  </view>
</van-popup>
