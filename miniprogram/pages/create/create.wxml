<navigation-bar title="{{isEditing ? '编辑训练' : '新建训练'}}" back="{{false}}"></navigation-bar>

<view class="page-shell create-page">
  <view class="hero">
    <view class="eyebrow">{{isEditing ? 'Edit Session' : 'New Session'}}</view>
    <view class="title">{{isEditing ? '修改这次训练' : '记录今天的训练'}}</view>
    <view class="subtitle">专注训练，持续进步，每一次记录都是成长。</view>
  </view>

  <view wx:if="{{isEditing}}" class="edit-banner">
    <view>正在编辑 {{currentDate}} 的训练记录</view>
    <view class="ghost-button" bindtap="cancelEditing">取消编辑</view>
  </view>

  <!-- 训练日期 -->
  <view class="form-block">
    <picker mode="date" value="{{currentDate}}" end="{{todayText}}" bindchange="onDateChange">
      <view class="date-row">
        <view class="date-icon-wrap">
          <van-icon name="calendar-o" size="44rpx" color="var(--brand-strong)" />
        </view>
        <view class="date-info">
          <text class="date-label">训练日期</text>
          <text class="date-value">{{currentDate}}</text>
        </view>
        <van-icon name="arrow" size="32rpx" color="var(--text-muted)" />
      </view>
    </picker>
    <input
      class="note-input"
      placeholder="副标题（选填，记录今天的状态 / 补充信息）"
      value="{{note}}"
      maxlength="60"
      bindinput="onNoteInput"
    />
  </view>

  <!-- 训练动作 -->
  <view class="form-block">
    <view class="field-label">训练动作</view>
    <view class="exercise-card" bindtap="openExercisePicker">
      <view class="exercise-card-body">
        <text class="exercise-card-name">{{selectedExerciseName}}</text>
        <view class="exercise-card-bottom">
          <view class="one-rm-inline">
            <van-tag plain color="var(--brand-strong)">1RM</van-tag>
            <text wx:if="{{selectedOneRepMax > 0}}" class="one-rm-value">{{selectedOneRepMax}} kg</text>
            <text wx:else class="one-rm-empty">未设置</text>
          </view>
          <view class="exercise-pick-btn">
            <text>选择动作</text>
            <van-icon name="arrow" size="24rpx" color="var(--brand-strong)" />
          </view>
        </view>
      </view>
      <image wx:if="{{selectedExerciseImage}}" class="exercise-card-img" src="{{selectedExerciseImage}}" mode="aspectFit" />
    </view>
    <!-- 1RM 重量 + 动作详情 -->
    <view class="exercise-info-row">
      <view class="exercise-info-card" bindtap="editOneRepMax">
        <text class="exercise-info-title">1RM 重量</text>
        <view class="exercise-info-body">
          <view class="orm-display">
            <text class="orm-value">{{selectedOneRepMax > 0 ? selectedOneRepMax : '--'}}</text>
            <text class="orm-unit">kg</text>
          </view>
          <view class="orm-edit-btn">
            <text>修改</text>
          </view>
        </view>
      </view>
      <view class="exercise-info-card" bindtap="openExerciseDetail">
        <text class="exercise-info-title">动作详情</text>
        <view class="exercise-info-body">
          <text class="exercise-info-desc">目标肌群 · 器械 · 要点</text>
          <van-icon name="arrow" size="32rpx" color="var(--text-muted)" />
        </view>
      </view>
    </view>
  </view>

  <!-- 训练组 -->
  <view class="form-block">
    <view class="field-row">
      <view class="field-label" style="margin-bottom:0">训练组</view>
    </view>
    <!-- 列头 -->
    <view class="set-header">
      <view class="set-header-spacer"></view>
      <text class="set-header-label weight-col">重量</text>
      <text class="set-header-label reps-col">次数</text>
      <text class="set-header-label rpe-col">RPE</text>
      <view class="set-header-spacer-end"></view>
    </view>
    <view wx:for="{{draftSets}}" wx:key="index" class="set-row-card">
      <view class="set-order {{index >= 3 ? 'set-order-alt' : ''}}">{{index + 1}}</view>
      <view class="set-weight-group">
        <block wx:if="{{item.inputMode === 'weight'}}">
          <input class="set-input weight-col" type="digit" placeholder="0" value="{{item.weight}}" data-index="{{index}}" bindinput="onSetWeightInput" />
        </block>
        <block wx:else>
          <input class="set-input weight-col" type="digit" placeholder="0" value="{{item.percent}}" data-index="{{index}}" bindinput="onSetPercentInput" />
        </block>
        <view wx:if="{{selectedOneRepMax > 0}}" class="unit-toggle" data-index="{{index}}" bindtap="toggleSetInputMode">
          <text>{{item.inputMode === 'weight' ? 'kg' : '%'}}</text>
          <van-icon name="arrow-down" size="18rpx" color="var(--text-muted)" />
        </view>
        <view wx:else class="unit-static">kg</view>
      </view>
      <view class="set-reps-group">
        <input class="set-input reps-col" type="number" placeholder="0" value="{{item.reps}}" data-index="{{index}}" bindinput="onSetRepsInput" />
        <text class="unit-label">次</text>
      </view>
      <input class="set-input rpe-col" type="digit" placeholder="0" value="{{item.rpe}}" data-index="{{index}}" bindinput="onSetRpeInput" />
      <view class="remove-set-btn" data-index="{{index}}" bindtap="removeSet">
        <van-icon name="delete-o" size="40rpx" color="var(--danger)" />
      </view>
    </view>
    <!-- 换算提示 -->
    <view wx:for="{{draftSets}}" wx:key="index">
      <view wx:if="{{item.inputMode === 'percent' && selectedOneRepMax > 0 && item.weight !== ''}}" class="conversion-hint">
        ≈{{item.weight}} kg · {{item.percent}}% of {{selectedOneRepMax}} kg
      </view>
    </view>
    <view class="add-set-row" bindtap="addSet">
      <van-icon name="plus" size="28rpx" color="var(--brand)" />
      <text class="add-set-text">添加组数</text>
    </view>
  </view>

  <!-- 保存按钮 -->
  <button class="primary-button full save-btn" bindtap="saveRecord">
    <van-icon name="records" size="36rpx" color="var(--text-on-brand)" />
    <text>{{isEditing ? '保存修改' : '保存训练记录'}}</text>
  </button>
</view>

<!-- 动作选择弹窗 -->
<van-popup
  wx:if="{{exercisePickerVisible}}"
  show="{{exercisePickerVisible}}"
  position="bottom"
  round
  custom-style="background: var(--surface); height: 72vh;"
  bind:close="closeExercisePicker"
>
  <view class="exercise-sheet-inner">
    <view class="sheet-handle"></view>
    <view class="sheet-title">选择训练动作</view>
    <view class="exercise-tabs-grid">
      <view
        wx:for="{{exerciseGroups}}"
        wx:key="id"
        class="exercise-tab-card {{activeGroupId === item.id ? 'active' : ''}}"
        data-id="{{item.id}}"
        bindtap="switchExerciseGroup"
      >
        <image class="exercise-tab-card-img" src="{{item.imageUrl}}" mode="aspectFit" />
        <text class="exercise-tab-card-label">{{item.label}}</text>
        <view wx:if="{{activeGroupId === item.id}}" class="exercise-tab-card-bar"></view>
      </view>
    </view>
    <scroll-view scroll-y="{{true}}" enhanced="{{true}}" class="exercise-scroll">
      <block wx:for="{{exerciseGroups}}" wx:key="id" wx:for-item="group">
        <view wx:if="{{activeGroupId === group.id}}" class="exercise-grid">
          <view
            wx:for="{{group.cards}}"
            wx:key="name"
            wx:for-item="item"
            class="exercise-option {{selectedExerciseName === item.name ? 'active' : ''}}"
            data-name="{{item.name}}"
            bindtap="chooseExercise"
          >
            <view class="exercise-thumb">
              <image wx:if="{{item.imageUrl}}" src="{{item.imageUrl}}" mode="aspectFill" class="exercise-thumb-img" />
              <view wx:else class="exercise-thumb-fallback">
                <text class="exercise-thumb-initial">{{item.initial}}</text>
              </view>
            </view>
            <view class="exercise-option-name">{{item.name}}</view>
            <view wx:if="{{item.shortDesc}}" class="exercise-option-desc">{{item.shortDesc}}</view>
          </view>
        </view>
      </block>
    </scroll-view>
  </view>
</van-popup>

<!-- 动作详情弹窗 -->
<van-popup
  show="{{exerciseDetailVisible}}"
  position="bottom"
  round
  custom-style="background: var(--surface); max-height: 80vh;"
  bind:close="closeExerciseDetail"
>
  <view class="detail-sheet-inner">
    <view class="sheet-handle"></view>
    <view class="sheet-title">{{selectedExerciseDetail.name}}</view>
    <scroll-view scroll-y="{{true}}" enhanced="{{true}}" class="detail-scroll">
      <!-- 动作介绍 -->
      <view wx:if="{{selectedExerciseDetail.description}}" class="detail-section">
        <text class="detail-section-title">动作介绍</text>
        <text class="detail-section-text">{{selectedExerciseDetail.description}}</text>
      </view>
      <!-- 目标肌群 -->
      <view wx:if="{{selectedExerciseDetail.targetMuscles}}" class="detail-section">
        <text class="detail-section-title">目标肌群</text>
        <view class="detail-tag-row">
          <van-tag
            wx:for="{{selectedExerciseDetail.targetMuscles}}"
            wx:key="*this"
            wx:if="{{item}}"
            plain
            color="var(--brand-strong)"
            custom-class="detail-tag"
          >{{item}}</van-tag>
        </view>
      </view>
      <!-- 使用器械 -->
      <view wx:if="{{selectedExerciseDetail.equipment}}" class="detail-section">
        <text class="detail-section-title">使用器械</text>
        <text class="detail-section-text">{{selectedExerciseDetail.equipment}}</text>
      </view>
      <!-- 技术要点 -->
      <view wx:if="{{selectedExerciseDetail.techniqueTips.length > 0}}" class="detail-section">
        <text class="detail-section-title">技术要点</text>
        <view class="detail-tips-list">
          <view wx:for="{{selectedExerciseDetail.techniqueTips}}" wx:key="index" class="detail-tip-item">
            <text class="detail-tip-index">{{index + 1}}</text>
            <text class="detail-tip-text">{{item}}</text>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</van-popup>
